#!/bin/bash

# Exit on error, undefined variable, or pipe failure
set -euo pipefail

echo "🚀 Starting System-Agnostic Setup for {{ .chezmoi.os }}..."

# --- 1. Installer Configuration via Chezmoi Templates ---
declare -A TOOLS

# Default core tools
TOOLS=(
    [git]="git"
    [zsh]="zsh"
    [tmux]="tmux"
    [neovim]="neovim"
    [curl]="curl"
    [unzip]="unzip"
)

{{ if eq .chezmoi.os "linux" -}}
    {{ if eq .chezmoi.osRelease.id "arch" "manjaro" -}}
    echo "🖥️  Detected OS: Arch/Manjaro"
    INSTALL_CMD="sudo pacman -S --noconfirm"
    TOOLS[ripgrep]="ripgrep"
    TOOLS[gcc]="base-devel"
    {{ else if eq .chezmoi.osRelease.id "ubuntu" "debian" "pop" -}}
    echo "🖥️  Detected OS: Debian/Ubuntu"
    sudo apt update
    INSTALL_CMD="sudo apt install -y"
    TOOLS[ripgrep]="ripgrep"
    TOOLS[gcc]="build-essential"
    {{ else if eq .chezmoi.osRelease.id "fedora" -}}
    echo "🖥️  Detected OS: Fedora"
    INSTALL_CMD="sudo dnf install -y"
    TOOLS[ripgrep]="ripgrep"
    TOOLS[gcc]="@development-tools"
    {{ end -}}
{{ else if eq .chezmoi.os "darwin" -}}
    echo "🖥️  Detected OS: macOS"
    if ! command -v brew &> /dev/null; then
        echo "🍺 Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    INSTALL_CMD="brew install"
    TOOLS[ripgrep]="ripgrep"
{{ else -}}
    echo "❌ Unsupported OS: {{ .chezmoi.os }}"
    exit 1
{{ end -}}

# --- 2. Install Core Packages ---
echo "📦 Installing packages with: $INSTALL_CMD"
for package in "${TOOLS[@]}"; do
    echo "   -> Installing $package..."
    $INSTALL_CMD "$package"
done

# --- 3. Install Ghostty ---
echo "👻 Attempting to install Ghostty..."
{{ if eq .chezmoi.os "darwin" -}}
    brew install --cask ghostty || echo "⚠️ Ghostty cask install failed."
{{ else if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
    sudo pacman -S --noconfirm ghostty || echo "⚠️ Ghostty not in repos yet."
{{ else -}}
    echo "⚠️ Ghostty is not in standard repos for {{ .chezmoi.os }} yet."
{{ end -}}

# --- 4. Install Mise (Version Manager) ---
echo "🔧 Installing Mise (CLI version manager)..."
if ! command -v mise &> /dev/null; then
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
    # Ensure it's in zshrc (chezmoi will manage the file, but this is a safety fallback)
    grep -q 'mise activate zsh' ~/.zshrc || echo 'eval "$(~/.local/bin/mise activate zsh)"' >> ~/.zshrc
else
    echo "   -> Mise already installed."
fi

# --- 5. Configure Languages (Go & Rust) ---
echo "🦀 Setting up Go and Rust via Mise..."
export PATH="$HOME/.local/bin:$PATH"
eval "$(mise activate bash)"
mise use --global go@latest
mise use --global rust@latest
mise use --global node@latest

# --- 6. Install Nerd Fonts ---
FONT_NAME="JetBrainsMono"
echo "🔡 Installing $FONT_NAME Nerd Font..."

{{ if eq .chezmoi.os "darwin" -}}
    FONT_DIR="$HOME/Library/Fonts"
{{ else -}}
    FONT_DIR="$HOME/.local/share/fonts"
{{ end -}}

if [ ! -f "$FONT_DIR/${FONT_NAME}NerdFont-Regular.ttf" ]; then
    mkdir -p "$FONT_DIR"
    curl -fLo "$FONT_DIR/${FONT_NAME}.zip" \
        "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${FONT_NAME}.zip"
    unzip -o "$FONT_DIR/${FONT_NAME}.zip" -d "$FONT_DIR"
    rm "$FONT_DIR/${FONT_NAME}.zip"
    {{ if ne .chezmoi.os "darwin" -}}
    fc-cache -fv
    {{ end -}}
else
    echo "   -> Fonts already detected."
fi

# --- 7. Change Shell ---
if [ "$SHELL" != "$(which zsh)" ]; then
    echo "🐚 Changing default shell to Zsh..."
    sudo chsh -s "$(which zsh)" "$USER"
fi

echo "✅ Setup complete! Restart your terminal."
