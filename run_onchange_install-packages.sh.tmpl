#!/bin/bash
# Soft pipefail — keeps -u and pipefail but network failures won't abort everything
set -uo pipefail

echo "🚀 Starting Dev Environment Setup..."

# ─────────────────────────────────────────────
# 1. Detect OS & Install Core Packages
# ─────────────────────────────────────────────
install_packages() {
    if command -v apt-get &>/dev/null; then
        echo "📦 Detected apt (Ubuntu/Debian)"
        sudo apt-get update -y
        sudo apt-get install -y \
            git zsh tmux neovim curl unzip \
            ripgrep bat fd-find fzf \
            gcc make cmake g++ \
            python3 python3-pip \
            nodejs npm \
            xclip xsel

        # eza — not in apt, install via binary
        if ! command -v eza &>/dev/null; then
            echo "📦 Installing eza..."
            curl -Lo /tmp/eza.tar.gz \
                "https://github.com/eza-community/eza/releases/latest/download/eza_x86_64-unknown-linux-gnu.tar.gz"
            tar -xzf /tmp/eza.tar.gz -C /tmp
            sudo mv /tmp/eza /usr/local/bin/eza
            rm -f /tmp/eza.tar.gz
        fi

        # zoxide — not in apt, install via script
        if ! command -v zoxide &>/dev/null; then
            echo "📦 Installing zoxide..."
            curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
        fi

    elif command -v dnf &>/dev/null; then
        echo "📦 Detected dnf (Fedora/RHEL)"
        sudo dnf install -y \
            git zsh tmux neovim curl unzip \
            ripgrep eza bat fd-find fzf zoxide \
            wl-clipboard \
            gcc make cmake gcc-c++ \
            python3 python3-pip \
            nodejs npm

    elif command -v pacman &>/dev/null; then
        echo "📦 Detected pacman (Arch)"
        sudo pacman -Sy --noconfirm \
            git zsh tmux neovim curl unzip \
            ripgrep eza bat fd fzf zoxide \
            wl-clipboard \
            gcc make cmake \
            python python-pip \
            nodejs npm

    elif command -v brew &>/dev/null; then
        echo "📦 Detected brew (macOS)"
        brew install \
            git zsh tmux neovim curl unzip \
            ripgrep eza bat fd fzf zoxide \
            gcc make cmake \
            python node

    else
        echo "⚠️  No supported package manager found — skipping core packages"
    fi
}

install_packages

# ─────────────────────────────────────────────
# 2. Oh My Zsh
# ─────────────────────────────────────────────
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "🐚 Installing Oh My Zsh..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

# ─────────────────────────────────────────────
# 3. ZSH Plugins
# ─────────────────────────────────────────────
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

if [ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]; then
    echo "🔌 Installing zsh-autosuggestions..."
    git clone https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
fi

if [ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ]; then
    echo "🔌 Installing zsh-syntax-highlighting..."
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
fi

# ─────────────────────────────────────────────
# 4. Starship
# ─────────────────────────────────────────────
if ! command -v starship &>/dev/null; then
    echo "🚀 Installing Starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- --yes
fi

# ─────────────────────────────────────────────
# 5. Mise
# ─────────────────────────────────────────────
if ! command -v mise &>/dev/null; then
    echo "🔧 Installing Mise..."
    curl https://mise.run | sh
fi

export PATH="$HOME/.local/bin:$PATH"

# ─────────────────────────────────────────────
# 6. Languages via Mise (non-fatal, with timeout)
# ─────────────────────────────────────────────
install_mise_languages() {
    if ! command -v mise &>/dev/null; then
        echo "⚠️  mise not found — skipping language installs"
        return 0
    fi

    eval "$(mise activate bash)" 2>/dev/null || true

    for lang in go rust node; do
        if mise current "$lang" &>/dev/null; then
            echo "✅ $lang already installed: $(mise current $lang)"
        else
            echo "📦 Installing $lang via mise..."
            MISE_FETCH_TIMEOUT_SECS=60 mise use --global "${lang}@latest" \
                && echo "✅ $lang installed" \
                || echo "⚠️  $lang install failed — run 'mise use --global ${lang}@latest' manually"
        fi
    done
}

# Run in subshell so a timeout/failure never aborts the parent script
(
    set +e
    install_mise_languages
)

# ─────────────────────────────────────────────
# 7. JetBrainsMono Nerd Font
# ─────────────────────────────────────────────
if [[ "$(uname)" == "Darwin" ]]; then
    if ! brew list --cask font-jetbrains-mono-nerd-font &>/dev/null; then
        echo "🔡 Installing JetBrainsMono Nerd Font via brew..."
        brew tap homebrew/cask-fonts 2>/dev/null || true
        brew install --cask font-jetbrains-mono-nerd-font
    fi
else
    FONT_DIR="$HOME/.local/share/fonts"
    FONT_NAME="JetBrainsMono"
    if [ ! -f "$FONT_DIR/${FONT_NAME}NerdFont-Regular.ttf" ]; then
        echo "🔡 Installing $FONT_NAME Nerd Font..."
        mkdir -p "$FONT_DIR"
        curl -fLo "$FONT_DIR/${FONT_NAME}.zip" \
            "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${FONT_NAME}.zip" \
            && unzip -o "$FONT_DIR/${FONT_NAME}.zip" -d "$FONT_DIR" \
            && rm "$FONT_DIR/${FONT_NAME}.zip" \
            && fc-cache -fv \
            || echo "⚠️  Font install failed — skipping"
    fi
fi

# ─────────────────────────────────────────────
# 8. Change Shell to Zsh
# ─────────────────────────────────────────────
if [ "$SHELL" != "$(command -v zsh)" ]; then
    echo "🐚 Changing default shell to Zsh..."
    sudo chsh -s "$(command -v zsh)" "$USER" \
        || echo "⚠️  Could not change shell — run: chsh -s \$(which zsh)"
fi

echo ""
echo "✅ Setup complete!"
echo "   If any language installs failed, run: mise use --global <lang>@latest"
echo "   Restart your terminal (or run: exec zsh) to apply all changes."
