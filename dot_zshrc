# Auto-list directory contents on cd
chpwd() {
    ls
}

# Smart cd with zoxide fallback
cd() {
    if [ $# -eq 0 ]; then
        builtin cd ~
    elif [ -d "$1" ]; then
        builtin cd "$@"
    elif command -v z &>/dev/null; then
        z "$@"
    else
        echo "Error: Directory not found or zoxide not installed."
        return 1
    fi
}

# Change directory (ls handled by chpwd)
cx() {
    cd "$@"
}

# Fuzzy find and change to directory
fcd() {
    local dir
    dir=$(fd --type d --hidden --follow --exclude .git | fzf --preview 'eza --tree --level=1 --icons --git {}') && cd "$dir"
}

# Quickly jump to project directories
unalias proj 2>/dev/null  # REQUIRED: Removes existing alias to allow function definition
proj() {
    local project
    project=$(fd --type d --max-depth 2 . "$PROJECTS" | fzf --preview 'eza --tree --level=1 --icons --git {}')
    [ -n "$project" ] && cd "$project"
}

# Create and enter directory
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Go up n directories
up() {
    local d=""
    local limit=${1:-1}
    for ((i=1; i<=limit; i++)); do
        d="../$d"
    done
    cd "$d"
}

# =========================================================================
# FUNCTIONS - FILE & SEARCH OPERATIONS
# =========================================================================
# Find file and copy path to clipboard
f() {
    local file
    file=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --style=numbers --color=always {}')
    [ -n "$file" ] && echo "$file" | wl-copy && echo "Copied: $file"
}

# Fuzzy find and open file in nvim
fv() {
    local file
    file=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --style=numbers --color=always {}')
    [ -n "$file" ] && nvim "$file"
}

# Open nvim (current dir if no args)
n() {
    if [ "$#" -eq 0 ]; then
        nvim .
    else
        nvim "$@"
    fi
}

# Open files with xdg-open in background
open() {
    xdg-open "$@" >/dev/null 2>&1 &
}

# Search in files with preview
rg() {
    if [ $# -eq 0 ]; then
        echo "Usage: rg <search_term>"
        return 1
    fi
    command rg --color=always --line-number --no-heading --smart-case "$@" |
        fzf --ansi \
            --delimiter ':' \
            --preview 'bat --style=numbers --color=always {1} --highlight-line {2}' \
            --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \
            --bind 'enter:execute(nvim {1} +{2})'
}

# Find and kill process
fkill() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m --preview 'echo {}' --preview-window down:3:wrap | awk '{print $2}')
    if [ -n "$pid" ]; then
        echo "$pid" | xargs kill -9
        echo "Killed process(es): $pid"
    fi
}

# =========================================================================
# FUNCTIONS - GIT WORKFLOWS
# =========================================================================
# Fuzzy git branch checkout
gcof() {
    local branch
    branch=$(git branch --all | grep -v HEAD | sed 's/^[* ]*//' | sed 's/remotes\///' | sort -u | fzf --preview 'git log --oneline --graph --color=always {}' --preview-window right:60%)
    [ -n "$branch" ] && git checkout "$branch"
}

# Fuzzy git log browser
glf() {
    local commit
    commit=$(git log --oneline --color=always | fzf --ansi --preview 'git show --color=always {1}' --preview-window right:60%)
    [ -n "$commit" ] && echo "$commit" | awk '{print $1}' | wl-copy
}

# Interactive git add
gai() {
    git status --short | fzf -m --preview 'git diff --color=always {2}' | awk '{print $2}' | xargs git add
}

# Quick commit with auto-generated message
gqc() {
    if [ -n "$(git status --porcelain)" ]; then
        git add -A
        local msg="${1:-Quick update: $(date +'%Y-%m-%d %H:%M')}"
        git commit -m "$msg"
        echo "Committed: $msg"
    else
        echo "Nothing to commit"
    fi
}

# Show git status for all repos in directory
gstatus() {
    local dir="${1:-.}"
    find "$dir" -name .git -type d -prune | while read -r gitdir; do
        local repo="${gitdir%/.git}"
        echo "\n📁 ${repo}"
        git -C "$repo" status -sb
    done
}

# =========================================================================
# FUNCTIONS - DEVELOPMENT HELPERS
# =========================================================================
# Create new project with common structure
newproject() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Usage: newproject <project_name>"
        return 1
    fi
    
    mkdir -p "$PROJECTS/$name"/{src,tests,docs,scripts}
    cd "$PROJECTS/$name"
    git init
    echo "# $name\n\nCreated: $(date)" > README.md
    echo "node_modules/\n.env\n*.log\nvenv/\n__pycache__/" > .gitignore
    echo "✨ Project created: $name"
}

# Run tests in watch mode
watch-test() {
    if [ -f "package.json" ]; then
        npm run test -- --watch
    elif [ -f "Cargo.toml" ]; then
        cargo watch -x test
    elif [ -f "go.mod" ]; then
        find . -name "*.go" | entr -c go test ./...
    else
        echo "No test configuration found"
    fi
}

# Port checker
port() {
    if [ $# -eq 0 ]; then
        echo "Usage: port <port_number>"
        return 1
    fi
    lsof -i ":$1" || echo "Port $1 is free"
}

# Kill process on port
killport() {
    if [ $# -eq 0 ]; then
        echo "Usage: killport <port_number>"
        return 1
    fi
    lsof -ti ":$1" | xargs kill -9 2>/dev/null && echo "Killed process on port $1" || echo "No process on port $1"
}

# Extract any archive
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"      ;;
            *.tar.gz)    tar xzf "$1"      ;;
            *.bz2)       bunzip2 "$1"      ;;
            *.rar)       unrar x "$1"      ;;
            *.gz)        gunzip "$1"       ;;
            *.tar)       tar xf "$1"       ;;
            *.tbz2)      tar xjf "$1"      ;;
            *.tgz)       tar xzf "$1"      ;;
            *.zip)       unzip "$1"        ;;
            *.Z)         uncompress "$1"   ;;
            *.7z)        7z x "$1"         ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Backup file with timestamp
backup() {
    if [ -f "$1" ]; then
        cp "$1" "$1.backup-$(date +%Y%m%d-%H%M%S)"
        echo "Backup created: $1.backup-$(date +%Y%m%d-%H%M%S)"
    else
        echo "File not found: $1"
    fi
}

# Code statistics
codestats() {
    echo "\n📊 Code Statistics for $(pwd)\n"
    echo "Total files: $(fd --type f | wc -l)"
    echo "Total directories: $(fd --type d | wc -l)"
    echo "\nLines of code:"
    fd --type f -e py -e js -e ts -e go -e rs -e java -e c -e cpp -e h -e hpp | xargs wc -l | tail -1
}

# =========================================================================
# FUNCTIONS - RANGER FILE MANAGER
# =========================================================================
ranger() {
    local IFS=$'\t\n'
    local tempfile="$(mktemp -t tmp.XXXXXX)"
    local ranger_cmd=(
        command ranger --cmd="map Q chain shell echo %d > \"$tempfile\"; quitall"
    )
    "${ranger_cmd[@]}" "$@"
    if [[ -f "$tempfile" && "$(cat -- "$tempfile")" != "$(pwd)" ]]; then
        cd -- "$(cat "$tempfile")" || return
    fi
    rm -f -- "$tempfile" 2>/dev/null
}

