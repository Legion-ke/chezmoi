# =========================================================================
# OH MY ZSH CONFIGURATION
# =========================================================================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(
    zsh-autosuggestions
    zsh-syntax-highlighting
    git
    docker
    web-search
    archlinux
    common-aliases
    extract
    gh
    zsh-interactive-cd
    command-not-found
    sudo
    copypath
    copyfile
