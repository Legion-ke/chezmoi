# Fuzzy directory jump
fcd() {
    local dir
    dir=$(fd --type d --hidden --follow --exclude .git | fzf --preview 'eza --tree --level=1 --icons --git {}') && cd "$dir"
}

# Quickly jump to project directories
proj() {
    local project
    project=$(fd --type d --max-depth 2 . "$PROJECTS" | fzf --preview 'eza --tree --level=1 --icons --git {}')
    [ -n "$project" ] && cd "$project"
}

mkcd() { mkdir -p "$1" && cd "$1"; }

# Find and open file in nvim
fv() {
    local file
    file=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --style=numbers --color=always {}')
    [ -n "$file" ] && nvim "$file"
}

# Fuzzy Kill
fkill() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m --preview 'echo {}' --preview-window down:3:wrap | awk '{print $2}')
    if [ -n "$pid" ]; then
        echo "$pid" | xargs kill -9
        echo "Killed: $pid"
    fi
}

# =========================================================================
# 7. KEY BINDINGS
# =========================================================================
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line
bindkey ' ' magic-space

# Copy buffer to clipboard (Fedora/Wayland)
copy-buffer-to-clipboard() {
    echo -n "$BUFFER" | wl-copy
    zle -M "Copied to clipboard"
}
zle -N copy-buffer-to-clipboard
bindkey '^X^C' copy-buffer-to-clipboard

# FZF bindings
bindkey -s '^P' 'fv\n'
bindkey -s '^F' 'fcd\n'

# =========================================================================
# 8. TOOL INITIALIZATION
# =========================================================================

# Mise (Runtimes)
if [ -f "$HOME/.local/bin/mise" ]; then
    eval "$($HOME/.local/bin/mise activate zsh)"
fi

# Zoxide (Smart cd) - Must stay near bottom
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
fi

# Starship, Atuin, UV, Thefuck
command -v starship &>/dev/null && eval "$(starship init zsh)"
command -v atuin &>/dev/null && eval "$(atuin init zsh)"
command -v uv &>/dev/null && eval "$(uv generate-shell-completion zsh)"
command -v thefuck &>/dev/null && eval "$(thefuck --alias)"

# =========================================================================
# 9. TMUX AUTO-START (MUST BE LAST)
# =========================================================================
if [[ -o interactive && -z "$TMUX" ]]; then
    if command -v tmux &>/dev/null; then
        tmux attach-session -t "$USER" || tmux new-session -s "$USER"
    fi
fi
