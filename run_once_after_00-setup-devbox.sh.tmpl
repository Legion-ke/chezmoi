{{ if (or (env "REMOTE_CONTAINERS") (env "DEVPOD")) -}}
#!/bin/bash
# 🎯 This script ONLY runs inside your DevPod/DevContainer boxes.

echo "📦 DevBox Detected: Installing core suite..."

# 1. Update and install basic CLI tools
sudo apt-get update
sudo apt-get install -y zsh tmux ripgrep fzf bat curl git build-essential software-properties-common

# 2. Install Neovim (Stable PPA)
if ! command -v nvim &> /dev/null; then
    sudo add-apt-repository -y ppa:neovim-ppa/stable
    sudo apt-get update
    sudo apt-get install -y neovim
fi

# 3. Install Mise (For Go, Node, Python)
if ! command -v mise &> /dev/null; then
    curl https://mise.jdx.dev/install.sh | sh
fi

# 4. Final ownership fix to prevent "Permission Denied"
sudo chown -R $(whoami):$(whoami) /workspaces

echo "✅ DevBox Provisioning Complete!"
{{ end -}}
