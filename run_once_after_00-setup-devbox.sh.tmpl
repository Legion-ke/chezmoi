#!/bin/bash
{{ if (or (env "REMOTE_CONTAINERS") (env "CODESPACES") (env "DEVPOD")) -}}
# 🎯 This script ONLY runs inside your DevPod/DevContainer boxes.
set -euo pipefail
echo "📦 DevBox Detected: Installing core suite..."

# 1. Update and install basic CLI tools
sudo apt-get update
sudo apt-get install -y \
    zsh tmux ripgrep fzf bat curl git \
    build-essential software-properties-common

# 2. Install eza (not in apt by default)
if ! command -v eza &>/dev/null; then
    curl -Lo /tmp/eza.tar.gz \
        "https://github.com/eza-community/eza/releases/latest/download/eza_x86_64-unknown-linux-gnu.tar.gz"
    tar -xzf /tmp/eza.tar.gz -C /tmp
    sudo mv /tmp/eza /usr/local/bin/eza
fi

# 3. Install zoxide
if ! command -v zoxide &>/dev/null; then
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# 4. Install Neovim (Stable PPA)
if ! command -v nvim &>/dev/null; then
    sudo add-apt-repository -y ppa:neovim-ppa/stable
    sudo apt-get update
    sudo apt-get install -y neovim
fi

# 5. Install Mise (for Go, Node, Python, Rust)
if ! command -v mise &>/dev/null; then
    curl https://mise.run | sh
fi

# 6. Fix workspace ownership
sudo chown -R "${USER}:${USER}" /workspaces

echo "✅ DevBox Provisioning Complete!"
{{ end -}}
